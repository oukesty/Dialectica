{
  "name": "dialectica",
  "version": "0.2.0",
  "private": true,
  "license": "MIT",
  "description": "AI-ready multi-party debate, discussion, and meeting platform for structured context capture, argument mapping, evaluation, and future provider integration.",
  "scripts": {
    "predev": "node ./scripts/clean-cache.js",
    "dev": "next dev",
    "prebuild": "node -e \"fs=require('fs');try{fs.rmSync('.next',{recursive:true,force:true})}catch{}\"",
    "build": "node ./scripts/next-build-safe.cjs",
    "start": "next start",
    "lint": "eslint .",
    "test": "node ./scripts/run-node-tests.mjs",
    "test:watch": "vitest --config vitest.config.mjs",
    "typecheck": "tsc --noEmit --incremental false",
    "clean": "node -e \"fs=require('fs');['.next','out','dist','.eslintcache','.tmp','.tools','.turbo','.swc','coverage','output'].forEach(d=>{try{fs.rmSync(d,{recursive:true,force:true})}catch{}});require('fs').readdirSync('.').filter(f=>f.endsWith('.log')||f.endsWith('.tsbuildinfo')).forEach(f=>{try{fs.unlinkSync(f)}catch{}})\"",
    "clean:all": "npm run clean && node -e \"fs=require('fs');try{fs.rmSync('node_modules',{recursive:true,force:true})}catch{}\"",
    "clean:artifacts": "node ./scripts/prune-artifacts.mjs",
    "check:size": "echo === Project size check === && du -sh .next node_modules data src public 2>/dev/null; echo --- Total: && du -sh . 2>/dev/null"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "clsx": "^2.1.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.552.0",
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "zod": "^4.1.12",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@types/node": "^24.6.0",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.38.0",
    "eslint-config-next": "^16.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
